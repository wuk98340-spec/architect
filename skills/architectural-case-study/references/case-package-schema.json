{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Architecture Case Package",
  "type": "object",
  "required": [
    "project_name",
    "architects",
    "location",
    "year",
    "program",
    "status",
    "case_type",
    "disambiguation_status",
    "disambiguation_candidates",
    "information_confidence",
    "incomplete_reason",
    "one_sentence_summary",
    "key_facts",
    "design_concept",
    "key_strategies",
    "spatial_ideas",
    "materials_structure",
    "site_context",
    "image_metadata",
    "download_mode",
    "sources",
    "uncertain_or_conflicting_info"
  ],
  "additionalProperties": false,
  "properties": {
    "project_name": {
      "type": "string"
    },
    "architects": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "location": {
      "type": "string"
    },
    "year": {
      "type": "string"
    },
    "program": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "case_type": {
      "type": "string",
      "description": "Cultural, education, hotel, housing, commercial, renovation, rural/tourism, green building, or another explicit type."
    },
    "disambiguation_status": {
      "enum": [
        "confirmed",
        "high_confidence",
        "ambiguous_waiting_for_user",
        "not_needed"
      ]
    },
    "disambiguation_candidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/disambiguationCandidate"
      }
    },
    "information_confidence": {
      "enum": [
        "high",
        "medium",
        "limited",
        "low"
      ]
    },
    "incomplete_reason": {
      "type": "string"
    },
    "one_sentence_summary": {
      "type": "string"
    },
    "key_facts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fact"
      }
    },
    "design_concept": {
      "type": "object",
      "required": [
        "sourced_concept",
        "ai_synthesis",
        "source_ids"
      ],
      "additionalProperties": false,
      "properties": {
        "sourced_concept": {
          "type": "string"
        },
        "ai_synthesis": {
          "type": "string"
        },
        "source_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "key_strategies": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": {
        "$ref": "#/$defs/strategy"
      }
    },
    "spatial_ideas": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/note"
      }
    },
    "materials_structure": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/note"
      }
    },
    "site_context": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/note"
      }
    },
    "image_metadata": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/imageMetadata"
      }
    },
    "download_mode": {
      "enum": [
        "not_requested",
        "requested",
        "partial",
        "completed"
      ]
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source"
      }
    },
    "uncertain_or_conflicting_info": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/uncertainty"
      }
    }
  },
  "$defs": {
    "disambiguationCandidate": {
      "type": "object",
      "required": [
        "candidate_project",
        "location",
        "architects",
        "year",
        "type",
        "main_sources",
        "confidence",
        "question_for_user"
      ],
      "additionalProperties": false,
      "properties": {
        "candidate_project": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "architects": {
          "type": "string"
        },
        "year": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "main_sources": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "type": "string"
        },
        "question_for_user": {
          "type": "string"
        }
      }
    },
    "fact": {
      "type": "object",
      "required": [
        "label",
        "value",
        "source_ids"
      ],
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string"
        },
        "value": {
          "type": "string"
        },
        "source_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "strategy": {
      "type": "object",
      "required": [
        "strategy_name",
        "design_problem",
        "specific_approach",
        "architectural_effect",
        "evidence",
        "source_ids",
        "related_image_ids",
        "transferable_lesson"
      ],
      "additionalProperties": false,
      "properties": {
        "strategy_name": {
          "type": "string"
        },
        "design_problem": {
          "type": "string"
        },
        "specific_approach": {
          "type": "string"
        },
        "architectural_effect": {
          "type": "string"
        },
        "evidence": {
          "type": "string",
          "description": "Directly sourced, inferred synthesis, or mixed."
        },
        "source_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "related_image_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "transferable_lesson": {
          "type": "string"
        }
      }
    },
    "note": {
      "type": "object",
      "required": [
        "text",
        "source_ids",
        "related_image_ids"
      ],
      "additionalProperties": false,
      "properties": {
        "text": {
          "type": "string"
        },
        "source_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "related_image_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "imageMetadata": {
      "type": "object",
      "required": [
        "id",
        "file_name",
        "image_type",
        "source_url",
        "source_site",
        "caption",
        "copyright_note",
        "recommended_use",
        "related_sections",
        "download_status",
        "failure_reason"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "file_name": {
          "type": "string"
        },
        "image_type": {
          "enum": [
            "01_hero",
            "02_site",
            "03_plan",
            "04_section",
            "05_elevation",
            "06_detail",
            "07_concept",
            "08_interior",
            "09_analysis"
          ]
        },
        "source_url": {
          "type": "string"
        },
        "source_site": {
          "type": "string"
        },
        "caption": {
          "type": "string"
        },
        "copyright_note": {
          "type": "string"
        },
        "recommended_use": {
          "type": "string"
        },
        "related_sections": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "download_status": {
          "enum": [
            "not_requested",
            "downloaded",
            "failed",
            "skipped"
          ]
        },
        "failure_reason": {
          "type": "string"
        }
      }
    },
    "source": {
      "type": "object",
      "required": [
        "id",
        "title",
        "url",
        "source_level",
        "publisher",
        "accessed_date",
        "notes"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "source_level": {
          "enum": [
            "level_a",
            "level_b",
            "level_c",
            "level_d"
          ]
        },
        "publisher": {
          "type": "string"
        },
        "accessed_date": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "uncertainty": {
      "type": "object",
      "required": [
        "topic",
        "description",
        "source_ids"
      ],
      "additionalProperties": false,
      "properties": {
        "topic": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "source_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
